# Arca configuration. Copy to .env and source it, or export the variables
# directly. Nothing here is required for L1 + local semantic caching --
# Databricks variables only matter for the shared/team cache and analytics.

# --- Databricks (optional: enables shared L2 cache, Delta analytics, MLflow) ---
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...            # never commit the real value
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/...

# Unity Catalog namespace Arca provisions and uses (tables become
# <catalog>.<schema>.cache_store and <catalog>.<schema>.usage_log)
# ARCA_CATALOG=main
# ARCA_SCHEMA=arca
# ARCA_VS_ENDPOINT=arca-vs-endpoint

# --- Cache tuning ---
# ARCA_SIMILARITY_THRESHOLD=0.90   # cosine threshold (safe at 0.90 via the L2 polarity guard)
# ARCA_L1_MAX_ENTRIES=1024         # in-process LRU size
# ARCA_L2_DEADLINE_S=0.5           # Vector Search lookup deadline (seconds)
# ARCA_LOCAL_L2=true               # local cosine fallback when Databricks absent
# ARCA_CACHE_ENABLED=true          # kill switch, re-read on every request

# --- L2 precision (retrieve-then-verify) ---
# ARCA_NLI_VERIFY=false            # opt-in NLI contradiction stage (default off; ~330MB model, ~10ms/candidate)
# ARCA_NLI_CONTRADICTION_THRESHOLD=0.5  # reject a candidate at/above this contradiction prob

# --- Proxy ---
# ARCA_PORT=8082

# --- Anthropic (only needed by scripts that call the real API) ---
# ANTHROPIC_API_KEY=sk-ant-...
